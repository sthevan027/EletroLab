{
  "name": "eletrilab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "**/*.css",
    "src/index.css",
    "src/main.tsx",
    "src/App.tsx"
  ],
  "scripts": {
    "dev": "vite",
